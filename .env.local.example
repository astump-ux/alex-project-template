# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — local development only
#
# Copy this file to `.env.local` and fill in real values from Vercel.
# `.env.local` is gitignored. NEVER commit real values.
# Production values live in Vercel → Project → Settings → Env Variables.
# ─────────────────────────────────────────────────────────────────────────────


# ─── ALWAYS REQUIRED ─────────────────────────────────────────────────────────

# Supabase — EU region project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sentry — smart-work-labs-gmbh org, DE region
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=                  # for source map uploads, used by build (CI/Vercel only)

# App URL — canonical, no trailing slash
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ─── OPTIONAL MODULE: STRIPE ─────────────────────────────────────────────────
# Uncomment & fill if you enabled the Stripe module.
# See docs/modules/stripe.md for setup.

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_STANDARD=price_...
# STRIPE_PRICE_PROFI=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...


# ─── OPTIONAL MODULE: AI PROVIDERS ───────────────────────────────────────────
# Uncomment & fill if you enabled the AI module.
# See docs/modules/ai.md for setup.

# ANTHROPIC_API_KEY=sk-ant-api03-...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...


# ─── OPTIONAL MODULE: TWILIO ─────────────────────────────────────────────────
# Uncomment & fill if you enabled the Twilio module.
# See docs/modules/twilio.md for setup.

# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_WHATSAPP_NUMBER=whatsapp:+49...


# ─── INTERNAL ────────────────────────────────────────────────────────────────
# For internal route-to-route authentication (rare; only if you have async jobs
# calling other routes inside the same Next.js app).

# INTERNAL_API_SECRET=
